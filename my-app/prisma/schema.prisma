// ─── Prisma Schema — bluedate.io ─────────────────────────────────────────────
// Database: Supabase (PostgreSQL)
// ORM:      Prisma
//
// Commands:
//   npx prisma migrate dev --name <name>   → create & apply a migration
//   npx prisma migrate deploy              → apply migrations in production
//   npx prisma generate                    → regenerate the client after schema changes
//   npx prisma studio                      → open GUI browser

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
  moderator
}

enum UserStatus {
  active
  inactive
  banned
  pending_verification
}

enum Gender {
  male
  female
  non_binary
  prefer_not_to_say
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  passwordHash String
  name        String
  role        UserRole   @default(user)
  status      UserStatus @default(pending_verification)
  gender      Gender?
  dateOfBirth DateTime?
  bio         String?
  avatarUrl   String?

  // JSON blobs — avoids extra join tables for simple nested objects
  // location    shape: { city?, country?, latitude?, longitude? }
  // preferences shape: { minAge, maxAge, genderPreference[], maxDistanceKm }
  location    Json?
  preferences Json?

  isEmailVerified Boolean   @default(false)
  lastSeenAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("users")
}
