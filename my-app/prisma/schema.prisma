// ─── Prisma Schema — bluedate.io ─────────────────────────────────────────────
// Database: Supabase (PostgreSQL)
// ORM:      Prisma
//
// Commands:
//   npx prisma migrate dev --name <name>   → create & apply a migration
//   npx prisma migrate deploy              → apply in production
//   npx prisma generate                    → regenerate client after schema changes
//   npx prisma studio                      → open GUI browser

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
  moderator
}

enum InviteCodeStatus {
  active
  used
}

// ─── Core auth table — intentionally minimal ─────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  phone               String   @unique
  email               String?  @unique
  role                UserRole @default(user)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  profile       Profile?
  preferences   Preferences?
  interests     Interests?
  personality   Personality?
  availability  Availability?
  aiSignals     AiSignals?
  photos        Photo[]
  openingMove   OpeningMove?
  prompts       Prompt[]
  inviteCodesCreated InviteCode[] @relation("InviteCodeCreator")
  inviteCodesUsed    InviteCode[] @relation("InviteCodeUsed")

  @@index([phone])
  @@map("users")
}

// ─── Profile — identity & bio ─────────────────────────────────────────────────

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  fullName    String?
  nickname    String?
  dateOfBirth DateTime?
  age         Int?
  city        String?
  bio         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Preferences — dating intent & filters ───────────────────────────────────

model Preferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  genderIdentity      String?
  genderPreference    String[]
  ageRangeMin         Int?
  ageRangeMax         Int?
  relationshipIntent  String?  // set only when user selects Date or BFF on step 3; "date" | "friendship" | goal
  relationshipGoals   String[] @default([]) // all selected goals (1–2) from step 5
  heightCm            Int?     // user height in centimeters, collected during onboarding
  heightCompleted     Boolean  @default(false)
  wantDate            Boolean  @default(true)  // user is actively looking for a date
  /// True once the user has explicitly chosen Date or BFF (step 3)
  datingModeCompleted Boolean  @default(false)
  photosStepCompleted Boolean  @default(false)
  promptsCompleted    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

// ─── Interests ────────────────────────────────────────────────────────────────

model Interests {
  id                  String   @id @default(cuid())
  userId              String   @unique
  hobbies             String[]
  favouriteActivities String[]
  musicTaste          String[]
  foodTaste           String[]
  bffInterests        String[] @default([])
  bffInterestsCompleted Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interests")
}

// ─── Personality ──────────────────────────────────────────────────────────────

model Personality {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  socialLevel             String?
  conversationStyle       String?
  funFact                 String?
  kidsStatus              String?
  kidsPreference          String?
  religion                String[] @default([])
  politics                String[] @default([])
  importantLifeCompleted  Boolean  @default(false)
  familyPlansCompleted    Boolean  @default(false)
  lifeExperiences         String[] @default([])
  lifeExperiencesCompleted Boolean @default(false)
  relationshipStatus      String?
  relationshipStatusCompleted Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personalities")
}

// ─── Availability ─────────────────────────────────────────────────────────────

model Availability {
  id     String   @id @default(cuid())
  userId String   @unique
  days   String[]
  times  String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

// ─── AI Signals (free-text, optional) ────────────────────────────────────────

model AiSignals {
  id              String  @id @default(cuid())
  userId          String  @unique
  selfDescription String?
  idealPartner    String?
  idealDate       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_signals")
}

// ─── Opening move — first message prompt (Date mode only) ───────────────────────

model OpeningMove {
  id        String   @id @default(cuid())
  userId    String   @unique
  // Stores a stable key for the chosen preset prompt (if any), e.g. "houseplants" or "dream_vacation".
  // For custom prompts this will be null.
  promptKey String?
  // The actual text of the opening move question shown to matches.
  promptText String
  // True when the user wrote their own opening move instead of choosing a preset.
  isCustom  Boolean  @default(false)
  // True once the user has completed this onboarding step.
  completed Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("opening_moves")
}

// ─── Invite codes (profile creation gate: men ↔ women) ───────────────────────

model InviteCode {
  id          String          @id @default(cuid())
  code        String          @unique
  createdById String
  usedById    String?
  status      InviteCodeStatus @default(active)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy User  @relation("InviteCodeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy    User? @relation("InviteCodeUsed", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([usedById])
  @@map("invite_codes")
}

// ─── WhatsApp Bot Session ─────────────────────────────────────────────────────

model WhatsAppSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  step      String   @default("WELCOME")
  tempData  Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("whatsapp_sessions")
}

// ─── Photos — ordered, stored in Supabase Storage ────────────────────────────

model Photo {
  id        String   @id @default(cuid())
  userId    String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("photos")
}

// ─── Profile prompts — \"What makes you, you?\" (Date intent only) ───────────────

model Prompt {
  id           String   @id @default(cuid())
  userId       String
  category     String
  questionKey  String
  questionText String
  answer       String
  imageUrl     String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("prompts")
}
