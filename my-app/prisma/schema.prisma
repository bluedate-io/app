// ─── Prisma Schema — bluedate.io ─────────────────────────────────────────────
// Database: Supabase (PostgreSQL)
// ORM:      Prisma
//
// Commands:
//   npx prisma migrate dev --name <name>   → create & apply a migration
//   npx prisma migrate deploy              → apply in production
//   npx prisma generate                    → regenerate client after schema changes
//   npx prisma studio                      → open GUI browser

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  user
  admin
  moderator
}

enum InviteCodeStatus {
  active
  used
}

enum MatchStatus {
  active
  unmatched
}

enum OptInStatus {
  opted_in
  opted_out
  opted_in_late
}

// ─── Core auth table — email-first auth ──────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  phone               String?  @unique
  email               String?  @unique
  collegeName         String?
  role                UserRole    @default(user)
  onboardingCompleted Boolean     @default(false)
  optInStatus         OptInStatus @default(opted_in)
  optedInAt           DateTime?
  lastMatchedAt       DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  profile       Profile?
  preferences   Preferences?
  interests     Interests?
  personality   Personality?
  availability  Availability?
  aiSignals     AiSignals?
  photos        Photo[]
  inviteCodesCreated InviteCode[] @relation("InviteCodeCreator")
  inviteCodesUsed    InviteCode[] @relation("InviteCodeUsed")
  matchesAsUser1     Match[]      @relation("MatchUser1")
  matchesAsUser2     Match[]      @relation("MatchUser2")
  matchesAsAdmin     Match[]      @relation("MatchAdmin")
  skipsAsUser1       AdminSkip[]  @relation("SkipUser1")
  skipsAsUser2       AdminSkip[]  @relation("SkipUser2")
  skipsAsAdmin       AdminSkip[]  @relation("SkipAdmin")
  sentMessages       Message[]    @relation("MessageSender")
  weeklyOptIns       WeeklyOptIn[]

  @@index([email])
  @@map("users")
}

// ─── College domain mapping ───────────────────────────────────────────────────

model CollegeDomain {
  id          String   @id @default(cuid())
  collegeName String   @unique
  domain      String   @unique
  createdAt   DateTime @default(now())

  @@map("college_domains")
}

// ─── Email OTP — stores codes server-side ────────────────────────────────────

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_otps")
}

// ─── Profile — identity & bio ─────────────────────────────────────────────────

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  fullName    String?
  nickname    String?
  dateOfBirth DateTime?
  age         Int?
  city        String?
  bio         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Preferences — dating intent & filters ───────────────────────────────────

model Preferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  genderIdentity      String?
  genderUpdateCount   Int      @default(0)
  genderPreference    String[]
  ageRangeMin         Int?
  ageRangeMax         Int?
  relationshipIntent  String?  // set only when user selects Date or BFF on step 3; "date" | "friendship" | goal
  relationshipGoals   String[] @default([]) // all selected goals (1–2) from step 5
  heightCm            Int?     // user height in centimeters, collected during onboarding
  heightCompleted     Boolean  @default(false)
  wantDate            Boolean  @default(true)  // user is actively looking for a date
  /// True once the user has explicitly chosen Date or BFF (step 3)
  datingModeCompleted Boolean  @default(false)
  photosStepCompleted Boolean  @default(false)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

// ─── Interests ────────────────────────────────────────────────────────────────

model Interests {
  id                  String   @id @default(cuid())
  userId              String   @unique
  hobbies             String[]
  favouriteActivities String[]
  musicTaste          String[]
  foodTaste           String[]
  bffInterests        String[] @default([])
  bffInterestsCompleted Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interests")
}

// ─── Personality ──────────────────────────────────────────────────────────────

model Personality {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  smokingHabit            String?
  drinkingHabit           String?
  funFact                 String?
  kidsStatus              String?
  kidsPreference          String?
  religion                String[] @default([])
  politics                String[] @default([])
  importantLifeCompleted  Boolean  @default(false)
  familyPlansCompleted    Boolean  @default(false)
  lifeExperiences         String[] @default([])
  lifeExperiencesCompleted Boolean @default(false)
  relationshipStatus      String?
  relationshipStatusCompleted Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personalities")
}

// ─── Availability ─────────────────────────────────────────────────────────────

model Availability {
  id     String   @id @default(cuid())
  userId String   @unique
  days   String[]
  times  String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

// ─── AI Signals (free-text, optional) ────────────────────────────────────────

model AiSignals {
  id              String  @id @default(cuid())
  userId          String  @unique
  selfDescription String?
  idealPartner    String?
  idealDate       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_signals")
}

// ─── Invite codes (profile creation gate: men ↔ women) ───────────────────────

model InviteCode {
  id          String          @id @default(cuid())
  code        String          @unique
  createdById String
  usedById    String?
  status      InviteCodeStatus @default(active)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy User  @relation("InviteCodeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy    User? @relation("InviteCodeUsed", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([usedById])
  @@map("invite_codes")
}

// ─── WhatsApp Bot Session ─────────────────────────────────────────────────────

model WhatsAppSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  step      String   @default("WELCOME")
  tempData  Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("whatsapp_sessions")
}

// ─── Photos — ordered, stored in Supabase Storage ────────────────────────────

model Photo {
  id        String   @id @default(cuid())
  userId    String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("photos")
}

// ─── Match — admin-curated user pairs ────────────────────────────────────────

model Match {
  id          String      @id @default(cuid())
  userId1     String
  userId2     String
  matchedBy   String
  status      MatchStatus @default(active)
  blurb       String?
  matchedAt   DateTime    @default(now())
  unmatchedAt DateTime?

  user1    User      @relation("MatchUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2    User      @relation("MatchUser2", fields: [userId2], references: [id], onDelete: Cascade)
  admin    User      @relation("MatchAdmin",  fields: [matchedBy], references: [id], onDelete: Restrict)
  messages Message[]

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
  @@map("matches")
}

// ─── AdminSkip — pairs the admin chose not to match ──────────────────────────

model AdminSkip {
  id        String   @id @default(cuid())
  userId1   String
  userId2   String
  skippedBy String
  skippedAt DateTime @default(now())

  user1 User @relation("SkipUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2 User @relation("SkipUser2", fields: [userId2], references: [id], onDelete: Cascade)
  admin User @relation("SkipAdmin",  fields: [skippedBy], references: [id], onDelete: Restrict)

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
  @@map("admin_skips")
}

// ─── Messages — in-app chat between matched users ────────────────────────────

model Message {
  id        String    @id @default(cuid())
  matchId   String
  senderId  String
  content   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@map("messages")
}

// ─── Weekly opt-in — users signal they want a match this week ─────────────────

model WeeklyOptIn {
  id          String   @id @default(cuid())
  userId      String
  weekStart   DateTime // Monday 00:00 UTC of the opt-in week
  mode        String   // "date" | "bff"
  description String?  // "describe your type" free text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart])
  @@map("weekly_opt_ins")
}

